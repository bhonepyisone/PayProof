#!/usr/bin/env bash
#
# PayProof Pre-Commit Hook
# Security check + syntax validation before every commit.
#

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# ─────────────────────────────────────────────
# a) SECRET CHECK — Block staged .env files
# ─────────────────────────────────────────────
STAGED_ENV=$(git diff --cached --name-only | grep -E '\.env$' || true)

if [ -n "$STAGED_ENV" ]; then
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}  COMMIT BLOCKED: .env file staged${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "  The following .env file(s) are staged for commit:"
    for f in $STAGED_ENV; do
        echo "    → $f"
    done
    echo ""
    echo "  .env files may contain secrets and must NEVER be committed."
    echo "  Unstage them with:  git reset HEAD .env"
    echo ""
    exit 1
fi

# ─────────────────────────────────────────────
# b) PYTHON SYNTAX CHECK
# ─────────────────────────────────────────────
STAGED_PY=$(git diff --cached --name-only | grep '\.py$' || true)
HAS_ERROR=0

if [ -n "$STAGED_PY" ]; then
    for file in $STAGED_PY; do
        if [ -f "$file" ]; then
            if ! python3 -m py_compile "$file"; then
                echo -e "${RED}  ✗ Syntax error in: $file${NC}"
                HAS_ERROR=1
            else
                echo -e "${GREEN}  ✓ $file${NC}"
                # Clean up compiled bytecode from the check
                rm -f "${file}c"
                # Also clean __pycache__ if it was created
                dir=$(dirname "$file")
                if [ -d "$dir/__pycache__" ]; then
                    rm -rf "$dir/__pycache__"
                fi
            fi
        fi
    done

    if [ "$HAS_ERROR" -eq 1 ]; then
        echo ""
        echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${RED}  COMMIT BLOCKED: Python syntax errors found${NC}"
        echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
        exit 1
    fi
fi

# ─────────────────────────────────────────────
# c) REMINDER
# ─────────────────────────────────────────────
echo ""
echo -e "${YELLOW}┌───────────────────────────────────────────┐${NC}"
echo -e "${YELLOW}│  REMINDER: Did you update report.md?      │${NC}"
echo -e "${YELLOW}│  ch-3/bhonepyisone/report.md              │${NC}"
echo -e "${YELLOW}└───────────────────────────────────────────┘${NC}"
echo ""

exit 0
